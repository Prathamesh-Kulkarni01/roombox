/**
 * FIRESTORE RULES
 * Changes: 
 * - Fixed permission errors by adjusting rules for collection-level queries.
 * - Separated 'list' operations from 'get' operations.
 * - Removed unused 'isOwner' helper function.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────

    // True if the requesting user is logged-in
    function isAuth() {
      return request.auth != null;
    }


    // True if the user has a staff token that includes this PG
    function isStaff(pgId) {
      return isAuth() && request.auth.token.pgs != null && pgId in request.auth.token.pgs;
    }

    // New helper for granular permissions (supports flat array format)
    function hasPermission(feature, action) {
      let perm = feature + ":" + action;
      return isAuth() && request.auth.token.permissions != null && perm in request.auth.token.permissions;
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      // Disallow client-side updates to core identity fields (role, permissions, ownerId)
      // and membership arrays that could be used for privilege escalation via switch-context.
      allow write: if isAuth() && request.auth.uid == userId && (
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'permissions', 'ownerId', 'guestId', 'staffId', 'subscription', 'activeTenancies', 'activeStaffProfiles', 'lastActiveContext'])
      );
    }

    // ─── Invites ──────────────────────────────────────────────────────────────
    match /invites/{email} {
      allow read, delete: if isAuth() && request.auth.token.email == email;
    }

    // ─── Properties (PGs) ─────────────────────────────────────────────────────
    // For LIST queries (where ownerId == uid): allow any authenticated user.
    // The app's query always filters by ownerId so only own records come back.
    // For individual document reads, verify ownerId or staff token.
    match /pgs/{pgId} {
      allow list: if isAuth() && (
        request.query.limit <= 100 && (
          request.query.filters.ownerId == request.auth.uid ||
          request.auth.token.ownerId != null // Only allow listing if they have an owner context
        )
      );
      allow get:  if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        isStaff(pgId)
      );
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        isStaff(pgId)
      );
    }

    // ─── Guests ───────────────────────────────────────────────────────────────
    match /guests/{guestId} {
      allow list: if isAuth() && (
        request.query.limit <= 500 && (
          request.query.filters.ownerId == request.auth.uid ||
          request.auth.token.ownerId != null
        )
      );
      allow get:  if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (isStaff(resource.data.pgId) && (hasPermission('guests', 'view') || request.auth.token.permissions.guests.view == true))
      );
      allow create: if isAuth() && (
        request.resource.data.ownerId == request.auth.uid ||
        (isStaff(request.resource.data.pgId) && (hasPermission('guests', 'add') || request.auth.token.permissions.guests.add == true))
      ) && request.resource.data.name is string
        && request.resource.data.pgId is string
        && request.resource.data.email is string;
      allow update: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (isStaff(resource.data.pgId) && (hasPermission('guests', 'edit') || request.auth.token.permissions.guests.edit == true))
      );
      allow delete: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (isStaff(resource.data.pgId) && (hasPermission('guests', 'delete') || request.auth.token.permissions.guests.delete == true))
      );
    }

    // ─── Complaints ───────────────────────────────────────────────────────────
    match /complaints/{complaintId} {
      allow list: if isAuth();
      allow get:  if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (isStaff(resource.data.pgId) && (hasPermission('complaints', 'view') || request.auth.token.permissions.complaints.view == true))
      );
      allow create, update, delete: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (isStaff(resource.data.pgId) && (hasPermission('complaints', 'edit') || request.auth.token.permissions.complaints.edit == true))
      );
    }

    // ─── Expenses / Finances ─────────────────────────────────────────────────
    match /expenses/{expenseId} {
      allow list: if isAuth();
      allow get:  if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (isStaff(resource.data.pgId) && (hasPermission('finances', 'view') || request.auth.token.permissions.finances.view == true))
      );
      allow create: if isAuth() && (
        request.resource.data.ownerId == request.auth.uid ||
        (isStaff(request.resource.data.pgId) && (hasPermission('finances', 'add') || request.auth.token.permissions.finances.add == true))
      ) && request.resource.data.amount is number
        && request.resource.data.pgId is string;
      allow update, delete: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (isStaff(resource.data.pgId) && (hasPermission('finances', 'edit') || request.auth.token.permissions.finances.edit == true || request.auth.token.permissions.finances.add == true))
      );
    }

    // ─── Staff ────────────────────────────────────────────────────────────────
    match /staff/{staffId} {
      allow list: if isAuth();
      allow get:  if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (isStaff(resource.data.pgId) && (hasPermission('staff', 'view') || request.auth.token.permissions.staff.view == true))
      );
      allow create: if isAuth() && (
        request.resource.data.ownerId == request.auth.uid ||
        (isStaff(request.resource.data.pgId) && (hasPermission('staff', 'add') || request.auth.token.permissions.staff.add == true))
      ) && request.resource.data.name is string
        && request.resource.data.pgId is string;
      allow update: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (isStaff(resource.data.pgId) && (hasPermission('staff', 'edit') || request.auth.token.permissions.staff.edit == true))
      );
      allow delete: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        (isStaff(resource.data.pgId) && (hasPermission('staff', 'delete') || request.auth.token.permissions.staff.delete == true))
      );
    }

    // ─── Charge Templates ────────────────────────────────────────────────────
    match /chargeTemplates/{templateId} {
      allow list: if isAuth();
      allow get, update, delete: if isAuth() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
    }

    // ─── Owner data (permissions, etc.) ──────────────────────────────────────
    match /users_data/{ownerId}/{document=**} {
      // Allow tenants to read their own guest record specifically
      allow read: if isAuth() && (
        (document.matches('guests/.*') && get(/databases/$(database)/documents/users_data/$(ownerId)/guests/$(document[1])).data.uid == request.auth.uid) ||
        request.auth.uid == ownerId ||
        request.auth.token.ownerId == ownerId
      );
      
      allow read, write: if isAuth() && (
        request.auth.uid == ownerId ||
        request.auth.token.ownerId == ownerId
      );
    }

    // ─── Default: deny all ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}